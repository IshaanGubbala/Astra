#!/bin/zsh
set -euo pipefail

HOST=127.0.0.1
PORT=8081
LLAMA=/opt/homebrew/bin/llama-server
MODEL=/Users/ishaangubbala/models/mythos-26b-a4b-prism-pro-dq.gguf

exec "${LLAMA}" \
  --host "${HOST}" \
  --port "${PORT}" \
  --model "${MODEL}" \
  --n-gpu-layers 99 \
  --ctx-size 32768 \
  --temp 1.0 \
  --top-p 0.95 \
  --top-k 20 \
  --parallel 6 \
  --min-p 0.0 \
  --flash-attn on
