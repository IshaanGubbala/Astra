# Stripe Standard Connect — register at https://dashboard.stripe.com/settings/connect
# STRIPE_SECRET_KEY: your platform secret key (sk_live_... or sk_test_...)
# STRIPE_CLIENT_ID:  your Connect client ID (ca_...)
# BACKEND_URL:       public URL of this backend (for OAuth redirect)
# FRONTEND_URL:      public URL of the frontend (for post-OAuth redirect)
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SCALE=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3003

# Production auth/admin controls
ASTRA_REQUIRE_AUTH=false
ASTRA_PLATFORM_ADMINS=
ASTRA_JWT_JWKS_URL=
ASTRA_JWT_SECRET=
ASTRA_TRUST_AUTH_HEADERS=false
ASTRA_CREDS_KEY=
ASTRA_ALERT_WEBHOOK_URL=

# Production connector tokens used by --seed-env-connectors
GITHUB_TOKEN=
VERCEL_TOKEN=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NOTION_TOKEN=
SENDGRID_API_KEY=

# NWRA LLC filing — Astra's company card (pays for founder's LLC filing fee)
