SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=your-gemini-key
AGENT_MODEL_BASE_URL=http://localhost:8080/v1
AGENT_MODEL_API_KEY=dummy
AGENT_MODEL_NAME=gemma4
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1

# Stripe Standard Connect — register at https://dashboard.stripe.com/settings/connect
# STRIPE_SECRET_KEY: your platform secret key (sk_live_... or sk_test_...)
# STRIPE_CLIENT_ID:  your Connect client ID (ca_...)
# BACKEND_URL:       public URL of this backend (for OAuth redirect)
# FRONTEND_URL:      public URL of the frontend (for post-OAuth redirect)
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3003

# Composio — OAuth for Gmail, LinkedIn, Twitter, GitHub PRs, Linear, Calendar, Notion
# Get key at https://app.composio.dev/settings
COMPOSIO_API_KEY=
